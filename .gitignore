.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
dist/
*.egg-info/
.superpowers/
.impeccable/
.DS_Store

# Sensitive inputs — never commit
sample_data/
.streamlit/
# Dataset-factory corpus: PDFs stay local; only the README is tracked
corpus/*
!corpus/README.md

# Generated benchmark / synthetic outputs
eval/datasets/
eval/runs/
eval/figures/
inspect_report.json
# recognizer-A/B output derived from real pages — never commit
predictions.json

# CRNN training-experiment run artifacts (checkpoints, metrics, plots)
experiments/khmer_crnn/runs/

# Promoted fine-tuned weights (large, regenerable via experiments/kiri_finetune/)
models/
# Fine-tuning artifacts (Tracks A/B): trainsets contain real-doc crops — never commit
experiments/kiri_finetune/trainset*/
experiments/kiri_finetune/run*/
experiments/kiri_finetune/*.log
experiments/layout_yolo/runs/
experiments/layout_yolo/*.pt
# derived from real pages (recall_taxonomy output)
scripts/_recall_taxonomy_output.json

# Presentation materials — kept on disk, not tracked in the repo
docs/presentations/

# React frontend
frontend/node_modules/
frontend/dist/
